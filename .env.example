# Git 仓库目录列表（每行一个路径，或使用 | 或空格分隔）
# 支持绝对路径或相对于本脚本所在目录的路径
# 空行和 # 开头的行会被忽略

# 多行写法（每行一个路径，行首可加空格）：
REPO_DIRS=
D:\frontend\my-journal-planning
D:\frontend\main\1.operations\node-telegram-bot-api
D:\frontend\main\nextnestnuxt\simple-nextjs-jwt
D:\frontend\main\1.operations\WhisprRT
D:\frontend\main\python\auto-deal-eth
D:\frontend\main\python\TrendRadar
D:\frontend\main\blog\share-blog


# 或单行用 | 或空格分隔：
# REPO_DIRS=C:/repo1|C:/repo2|D:/repo3

# ---------- 任务提醒脚本 task_notifier.py ----------
# 任务列表来源二选一：本地 JSON 或 API
# TASK_CONFIG=tasks_config.json
# TASK_API_URL=https://api.example.com/tasks

# ---------- Telethon（telegram/ 目录脚本）----------
# 在 https://my.telegram.org 创建应用后填写；api_hash 勿提交到 Git，泄露请 Regenerate
# TELEGRAM_API_ID=12345678
# TELEGRAM_API_HASH=your_api_hash_here
# 会话文件名前缀，会在当前工作目录生成 .session 文件（用户号与 Bot 请用不同前缀各存一份）
# TELEGRAM_SESSION_NAME=telegram_client
# list_groups.py 仅支持「用户号」会话；若曾用 Bot token 登录同一前缀，会报 BotMethodInvalidError，需换 SESSION 或删 .session 后用手机登录
# 可选：listen.py 仅监听这些 chat id（逗号分隔）；留空则监听所有对话
# TELEGRAM_TARGET_CHAT_IDS=-1001234567890,-1009876543210
# 可选：list_groups.py 每个群拉取条数、单条预览长度
# TELEGRAM_RECENT_MESSAGES=10
# TELEGRAM_MESSAGE_PREVIEW_LEN=120
# 连接调试：默认 INFO；排查问题时设为 DEBUG（会刷屏 Encrypting/RPC 等属正常现象）
# TELEGRAM_LOG_LEVEL=DEBUG
# TELEGRAM_CONNECT_TIMEOUT=60
# （已移除对 connect 的 asyncio.wait_for；超时请用 TELEGRAM_CONNECT_TIMEOUT）
# 同一 TELEGRAM_SESSION_NAME 默认单进程（*.session.runlock）；要强行多开（易 SQLite 卡死）设 1
# TELEGRAM_ALLOW_MULTI=0
# TELEGRAM_CONNECTION_RETRIES=5
# 直连卡在 149.154.x.x:443 时：走本机代理（Clash / Surge 等开启「允许局域网」后填端口）
# pip 需装 python-socks[asyncio]（已在 telegram/requirements.txt）
# TELEGRAM_PROXY_URL=socks5://127.0.0.1:7891
# TELEGRAM_PROXY_URL=http://127.0.0.1:7890
# 或使用 Telegram MTProxy（与上面二选一）：
# TELEGRAM_MT_PROXY_HOST=proxy.example.com
# TELEGRAM_MT_PROXY_PORT=443
# TELEGRAM_MT_PROXY_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
#
# ---------- poll_groups.py（定时只拉「列表里」的群）----------
# 与 listen.py 二选一：轮询 vs 实时事件。监控 id 列表 = 环境变量 + monitored_groups.txt 合并
# TELEGRAM_MONITORED_GROUP_IDS=-1001234567890,-1009876543210
# TELEGRAM_MONITORED_GROUPS_FILE=telegram/monitored_groups.txt
# TELEGRAM_POLL_INTERVAL=30
# TELEGRAM_POLL_STATE_FILE=telegram/.poll_state.json
# poll_groups 启动时打印最近若干条历史并设水位（默认 10）
# TELEGRAM_BOOTSTRAP_MESSAGES=10
# 图片/贴纸等：终端只显示类型；设为 1 时下载到 telegram/media/（或 TELEGRAM_MEDIA_DIR）
# TELEGRAM_DOWNLOAD_MEDIA=0
# TELEGRAM_MEDIA_DIR=telegram/media
# 同一 .session 不能多进程同时用；仍遇 database is locked 时可加大等待/重试
# TELEGRAM_SQLITE_BUSY_TIMEOUT=120
# TELEGRAM_SQLITE_CONNECT_RETRIES=8
